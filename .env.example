# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://novatip:novatip@localhost:5432/novatip

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
# testnet | mainnet | local
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed tip_splitter contract ID
TIP_SPLITTER_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# USDC Stellar Asset Contract ID
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Ledger to start indexing from (set to current ledger on first deploy)
INDEXER_START_LEDGER=0

# ── Notifications (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=tips@novatip.xyz

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
